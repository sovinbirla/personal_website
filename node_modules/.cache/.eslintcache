[{"/Users/sovin/personal_website/src/index.js":"1","/Users/sovin/personal_website/src/pages/Home.js":"2","/Users/sovin/personal_website/src/components/Navbar.js":"3","/Users/sovin/personal_website/src/pages/Projects.js":"4","/Users/sovin/personal_website/src/pages/Contact.js":"5","/Users/sovin/personal_website/src/pages/About.js":"6","/Users/sovin/personal_website/src/App.js":"7","/Users/sovin/personal_website/src/components/Footer.js":"8"},{"size":919,"mtime":1687801300043,"results":"9","hashOfConfig":"10"},{"size":565,"mtime":1687815208978,"results":"11","hashOfConfig":"10"},{"size":2158,"mtime":1687798620495,"results":"12","hashOfConfig":"10"},{"size":5821,"mtime":1687763026701,"results":"13","hashOfConfig":"10"},{"size":1193,"mtime":1687781006278,"results":"14","hashOfConfig":"10"},{"size":10355,"mtime":1687818744450,"results":"15","hashOfConfig":"10"},{"size":558,"mtime":1687763012402,"results":"16","hashOfConfig":"10"},{"size":1525,"mtime":1687806442632,"results":"17","hashOfConfig":"10"},{"filePath":"18","messages":"19","suppressedMessages":"20","errorCount":0,"fatalErrorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":"21","usedDeprecatedRules":"22"},"1br16k3",{"filePath":"23","messages":"24","suppressedMessages":"25","errorCount":0,"fatalErrorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":"26"},{"filePath":"27","messages":"28","suppressedMessages":"29","errorCount":0,"fatalErrorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":"30","usedDeprecatedRules":"22"},{"filePath":"31","messages":"32","suppressedMessages":"33","errorCount":0,"fatalErrorCount":0,"warningCount":7,"fixableErrorCount":0,"fixableWarningCount":0,"source":"34","usedDeprecatedRules":"22"},{"filePath":"35","messages":"36","suppressedMessages":"37","errorCount":0,"fatalErrorCount":0,"warningCount":6,"fixableErrorCount":0,"fixableWarningCount":0,"source":"38","usedDeprecatedRules":"22"},{"filePath":"39","messages":"40","suppressedMessages":"41","errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"42"},{"filePath":"43","messages":"44","suppressedMessages":"45","errorCount":0,"fatalErrorCount":0,"warningCount":11,"fixableErrorCount":0,"fixableWarningCount":0,"source":"46","usedDeprecatedRules":"22"},{"filePath":"47","messages":"48","suppressedMessages":"49","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"50"},"/Users/sovin/personal_website/src/index.js",["51","52","53","54"],[],"import React from \"react\";\nimport { createRoot } from \"react-dom/client\";\nimport {\n  createBrowserRouter,\n  RouterProvider,\n  Route,\n  Link,\n  Outlet,\n} from \"react-router-dom\";\nimport \"./App.css\";\nimport App from \"./App\";\nimport Navbar from \"./components/Navbar.js\";\nimport Home from \"./pages/Home.js\";\nimport About from \"./pages/About.js\";\nimport Projects from \"./pages/Projects.js\";\nimport Contact from \"./pages/Contact.js\";\n\nconst router = createBrowserRouter([\n  {\n    element: <App />,\n    children: [\n      {\n        path: \"/\",\n        // path: \"/\",\n        element: <Home />,\n      },\n      {\n        path: \"/about\",\n        element: <About />,\n      },\n      {\n        path: \"/projects\",\n        element: <Projects />,\n      },\n      {\n        path: \"/contact\",\n        element: <Contact />,\n      },\n    ],\n  },\n]);\n\ncreateRoot(document.getElementById(\"root\")).render(\n  <RouterProvider router={router} />\n);\n",[],"/Users/sovin/personal_website/src/pages/Home.js",["55","56","57","58"],[],"import React from \"react\";\nimport { Link } from \"react-router-dom\";\nimport {\n  BrowserRouter as Router,\n  Route,\n  Routes,\n  Switch,\n} from \"react-router-dom\";\nimport \"../styles/Home.css\";\n\nfunction Home() {\n  return (\n    <div class=\"hero\" id=\"home\">\n      <div class=\"hero__container\">\n        <h1 class=\"hero__heading\">\n          <span>Welcome</span>\n        </h1>\n        <p class=\"hero__description\">I am Sovin Birla</p>\n        <Link to=\"/about\" class=\"hero__btn\">\n          Learn about me\n        </Link>\n      </div>\n    </div>\n  );\n}\n\nexport default Home;\n","/Users/sovin/personal_website/src/components/Navbar.js",["59","60","61","62"],[],"import React, { useState } from \"react\";\nimport { Link } from \"react-router-dom\";\nimport \"./Navbar.css\";\nimport Home from \"../pages/Home.js\";\nimport About from \"../pages/About.js\";\nimport Projects from \"../pages/Projects.js\";\nimport Contact from \"../pages/Contact.js\";\nimport { NavLink } from \"react-router-dom\";\nimport { FaBars, FaTimes } from \"react-icons/fa\";\n\nfunction Navbar() {\n  const [bool_menu, toggle_menu] = useState(false);\n\n  const openMenu = () => toggle_menu(!bool_menu);\n  const closeMenu = () => toggle_menu(false);\n\n  return (\n    <>\n      <nav class=\"navbar\">\n        <div class=\"navbar__container\">\n          <Link to=\"/\" className=\"navbar__logo\" onClick={closeMenu}>\n            Sovin Birla\n          </Link>\n          <div class=\"navbar__toggle\" onClick={openMenu}>\n            {bool_menu ? <FaTimes /> : <FaBars />}\n          </div>\n          <ul class={bool_menu ? \"navbar__menu active\" : \"navbar__menu\"}>\n            <li class=\"navbar__item\">\n              <NavLink\n                to=\"/\"\n                className={({ isActive }) =>\n                  \"top_links\" + (isActive ? \" activated\" : \"\")\n                }\n                onClick={closeMenu}>\n                <span>Home</span>\n              </NavLink>\n            </li>\n            <li class=\"navbar__item\">\n              <NavLink\n                to=\"/about\"\n                className={({ isActive }) =>\n                  \"top_links\" + (isActive ? \" activated\" : \"\")\n                }\n                onClick={closeMenu}>\n                About\n              </NavLink>\n            </li>\n            <li class=\"navbar__item\">\n              <NavLink\n                to=\"/projects\"\n                className={({ isActive }) =>\n                  \"top_links\" + (isActive ? \" activated\" : \"\")\n                }\n                onClick={closeMenu}>\n                Projects\n              </NavLink>\n            </li>\n            <li class=\"navbar__btn\">\n              <NavLink to=\"/contact\" className=\"button\" onClick={closeMenu}>\n                Contact\n              </NavLink>\n            </li>\n          </ul>\n        </div>\n      </nav>\n    </>\n  );\n}\n\nexport default Navbar;\n","/Users/sovin/personal_website/src/pages/Projects.js",["63","64","65","66","67","68","69"],[],"import React, { useState } from \"react\";\nimport \"../styles/Projects.css\";\nimport { Link } from \"react-router-dom\";\nimport {\n  BrowserRouter as Router,\n  Route,\n  Routes,\n  Switch,\n} from \"react-router-dom\";\nimport { render } from \"react-dom\";\n\nfunction Projects() {\n  const experiences = [\n    {\n      id: 0,\n      name: \"TBD\",\n      // title: \"SWE\",\n      // location: \"Chicago, IL\",\n      // startDate: \"Jun 2021\",\n      // endDate: \"Jan 2023\",\n      // image_url:\n      //   \"https://www.mavenwave.com/wp-content/uploads/2014/10/image03.png\",\n      // points: [\n      //   \"Extracted data to forecast In-N-Out locations’ exposure to flood risk using Big Query, Keras, Pandas, and Plotly\",\n      //   \"Deployed the full stack In-N-Out application using Django and React to GKE clusters in GCP using Helm charts for multiple versioning\",\n      //   \"Served a full stack Dockerized application with React and Firebase for a plug-and-play POS system, for Mcdonald's with Raspberry Pi’s as Edge terminals, as a solution to main POS system failure\",\n      // ],\n    },\n    {\n      id: 1,\n      name: \"Maven Wave\",\n      title: \"SWE\",\n      location: \"Chicago, IL\",\n      startDate: \"Jun 2021\",\n      endDate: \"Jan 2023\",\n      image_url:\n        \"https://www.mavenwave.com/wp-content/uploads/2014/10/image03.png\",\n      points: [\n        \"Extracted data to forecast In-N-Out locations’ exposure to flood risk using Big Query, Keras, Pandas, and Plotly\",\n        \"Deployed the full stack In-N-Out application using Django and React to GKE clusters in GCP using Helm charts for multiple versioning\",\n        \"Served a full stack Dockerized application with React and Firebase for a plug-and-play POS system, for Mcdonald's with Raspberry Pi’s as Edge terminals, as a solution to main POS system failure\",\n      ],\n    },\n    {\n      id: 2,\n      name: \"KPMG\",\n      title: \"Data Science Intern\",\n      location: \"Manhattan, NY\",\n      startDate: \"Jun 2020\",\n      endDate: \"Aug 2020\",\n      image_url:\n        \"https://upload.wikimedia.org/wikipedia/commons/9/9d/KPMG_logo.svg\",\n      points: [\n        \"Purposed the Zillow API to classify areas of highest price increase in appreciation rates given any region\",\n        \"Learned about reading real estate data and implementing HTTP requests with the MLS Record API\",\n        \"Communicated with execs in the Lighthouse Analytics practice to discover more about their practice and their specific functions within their vertical\",\n      ],\n    },\n    // {\n    //   id: 3,\n    //   name: \"Conagra Brands\",\n    //   title: \"SWE Intern\",\n    //   location: \"Omaha, NE\",\n    //   startDate: \"Jun 2020\",\n    //   endDate: \"Aug 2020\",\n    //   points: [\n    //     \"Built an Ionic app with an Angular Framework for plants to avoid plant workers from re-touching the punch-in-the-clock amidst the COVID-19 scare\",\n    //     \"Improved efficiency by 13.7% across all 67 manufacturing plants with time-keeping the app\",\n    //     \"Led a team of 15 interns to provide educational support to students interested in CS from the Big Brother Big Sister organization\",\n    //   ],\n    // },\n    // {\n    //   id: 4,\n    //   name: \"Fiserv\",\n    //   title: \"SWE Intern\",\n    //   location: \"Omaha, NE\",\n    //   startDate: \"Jun 2019\",\n    //   endDate: \"Aug 2019\",\n    //   points: [\n    //     \"Wrote React code to build an app, Jobpose, to serve as an internal job search website\",\n    //     \"Created SQL databases in Toad for Fiserv clients with specific field requirements in the PRD environment with PeopleSoft\",\n    //     \"Worked on processes that prepped sensitive data for the production environment with VBA\",\n    //   ],\n    // },\n    {\n      id: 5,\n      name: \"IRisk Lab\",\n      title: \"Quantitative Research Assistant\",\n      location: \"Champaign, IL\",\n      startDate: \"Aug 2018\",\n      endDate: \"Dec 2018\",\n      image_url:\n        \"https://media.licdn.com/dms/image/C4E0BAQH9W23qd7z8YA/company-logo_200_200/0/1555703173496?e=2147483647&v=beta&t=jVuE2GLE4X0lDmBzyiYTF8p9opJk6FeTjo8Lu6JAsX8\",\n      points: [\n        \"Worked under Professor Linders to confirm his theory about the HIX(Herd-Behavior Index), a derivation of the VIX (Volatility Index)\",\n        \"Analyzed S&P 500 options data to figure out the behavior of the market after major disruptions\",\n        \"Used Python to formulate edge cases using pytest for the HIX index and MySQL to tabulate the vast options data\",\n      ],\n    },\n  ];\n\n  // const closeCard = ({experience.id}) => setFlip(false);\n\n  const listExperiences = experiences.map((experience) => (\n    <div class=\"front_card\" key={experience.id}>\n      {/* <img src={experience.image_url} /> */}\n      <h1>{experience.name}</h1>\n      <h3>{experience.title}</h3>\n      <h3>{experience.location}</h3>\n      <p>\n        {experience.startDate} - {experience.endDate}\n      </p>\n      {/* {experience.points.map((point) => (\n        <p>{point}</p>\n      ))} */}\n    </div>\n  ));\n\n  return (\n    <div class=\"projects\" id=\"projects\">\n      <div className=\"title\">The Past</div>\n      <div class=\"projects__wrapper\">{listExperiences}</div>\n    </div>\n  );\n}\n\nexport default Projects;\n\nfunction Project({ experience }) {\n  const [flip, setFlip] = useState(false);\n\n  const flipCard = () => setFlip(!flip);\n\n  const front_list = (\n    <div class=\"front_card\" key={experience.id}>\n      <h1>{experience.name}</h1>\n      <h3>{experience.title}</h3>\n      <h3>{experience.location}</h3>\n      {experience.startDate} - {experience.endDate}\n      <button onClick={flipCard}>Flip</button>\n    </div>\n  );\n\n  const back_list = (\n    <div class=\"front_card\" key={experience.id}>\n      {experience.points.map((point) => (\n        <p>{point}</p>\n      ))}\n      <button onClick={flipCard}>Flip</button>\n    </div>\n  );\n\n  return flip ? front_list : back_list;\n}\n","/Users/sovin/personal_website/src/pages/Contact.js",["70","71","72","73","74","75"],[],"import React from \"react\";\nimport { Link } from \"react-router-dom\";\nimport {\n  BrowserRouter as Router,\n  Route,\n  Routes,\n  Switch,\n} from \"react-router-dom\";\n// import App from \"../App\";\n// import \"bootstrap/dist/css/bootstrap.min.css\";\nimport \"../styles/Contact.css\";\n\nfunction Contact() {\n  const myFunction = () => {\n    // Copy the text inside the text field\n    navigator.clipboard.writeText(\"sovin.birla123@gmail.com\");\n\n    // Alert the copied text\n    alert(\"Copied Sovin's Email\");\n\n    return <></>;\n  };\n  return (\n    <div class=\"main\" id=\"sign-up\">\n      <div class=\"main__container\">\n        <div class=\"contact__content\">\n          <h1>So.... that's me</h1>\n          <p>Contact me if you have questions or concerns.</p>\n          <button key=\"test\" class=\"contact_btn\">\n            Email Me <span>at sovin.birla123@gmail.com</span>\n          </button>\n        </div>\n        {/* <div class=\"contact__img--container\">\n          <div class=\"contact__img--card\">\n             <img src=\"https://u-static.fotor.com/images/text-to-image/result/PRO-ca46ab06f1d043929524a44fa3316cf5.jpg\" />\n          </div>\n        </div> */}\n      </div>\n    </div>\n  );\n}\n\nexport default Contact;\n","/Users/sovin/personal_website/src/pages/About.js",["76","77"],[],"import React, { useState } from \"react\";\n// import App from \"../App\";\nimport \"../styles/About.css\";\nimport { Link } from \"react-router-dom\";\n\nfunction About() {\n  const [toggleState, setToggleState] = useState(1);\n\n  const toggleTab = (index) => {\n    setToggleState(index);\n  };\n\n  return (\n    <div class=\"about_main\">\n      <div class=\"about__container\">\n        <div class=\"about__img--card\">\n          <img src=\"data:image/jpeg;base64,\" />{\" \"}\n        </div>\n\n        <div class=\"about__content\">\n          <h1>Who am I?</h1>\n          <p>\n            I am Sovin Birla. I am software engineer. I went to U of I and took\n            some really cool courses and built some projects. I am will be going\n            to Georgia Tech for a Master's in Quantitative and Computational\n            Finance.\n          </p>\n\n          <div class=\"container_uiuc\">\n            <div className=\"uiuc-bloc-tabs\">\n              <div\n                className={\n                  toggleState === 1 ? \"uiuc-tabs active-tabs\" : \"uiuc-tabs\"\n                }\n                onClick={() => toggleTab(1)}>\n                Coursework\n              </div>\n              <div\n                className={\n                  toggleState === 2 ? \"uiuc-tabs active-tabs\" : \"uiuc-tabs\"\n                }\n                onClick={() => toggleTab(2)}>\n                Cool Stuff\n              </div>\n            </div>\n\n            <div className=\"uiuc_content_tabs\">\n              <div\n                className={\n                  toggleState === 1\n                    ? \"uiuc_content active-content\"\n                    : \"uiuc_content\"\n                }>\n                <ul>\n                  <li>Data Structures(CS 225)</li>\n                  <li>Algorithms(CS 374)</li>\n                  <li>Applied Machine Learning(CS 498)</li>\n                  <li>Time Series Analysis(STAT 429)</li>\n                  <li>Numerical Methods(CS 357)</li>\n                </ul>\n              </div>\n\n              <div\n                className={\n                  toggleState === 2\n                    ? \"uiuc_content active-content\"\n                    : \"uiuc_content\"\n                }>\n                <ul>\n                  <li>\n                    <b>Monte Carlo Simulation Poker:</b>\n                  </li>\n                  <p>\n                    I built the entire gameplay of Poker and used Markov Chain\n                    Monte Simulation to calculate the winning hand probabilities\n                    of each player after each round of play.\n                  </p>\n                  <li>\n                    <b>Github Social Media:</b>\n                    <p>\n                      Built a react app and used axios to build a social media\n                      app for software developers on campus by templating\n                      Instagram's user profile.\n                    </p>\n                  </li>\n                  <li>\n                    <b>UNO Game:</b>\n                    <p>\n                      Built an interactive visualization for UNO gameplay in\n                      Android Studio.\n                    </p>\n                  </li>\n                  <li>\n                    <b>Goodreads MongoDB Database:</b>\n                    <p>\n                      I scraped Goodreads using Beautiful Soup and stored the\n                      top \"x\" number of books and authors in a MongoDB instance.\n                      I then used GraphQL to post filtered API requests to a\n                      React frontend.\n                    </p>\n                  </li>\n                </ul>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"Gtech\">\n            <p></p>\n            <p>Stay tuned more updates.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n\nexport default About;\n","/Users/sovin/personal_website/src/App.js",["78","79","80","81","82","83","84","85","86","87","88"],[],"import logo from \"./logo.svg\";\nimport \"./App.css\";\nimport About from \"./pages/About\";\nimport Home from \"./pages/Home\";\nimport Projects from \"./pages/Projects\";\nimport Contact from \"./pages/Contact\";\nimport React, { useState } from \"react\";\nimport {\n  BrowserRouter as Router,\n  Link,\n  Route,\n  Routes,\n  Switch,\n  Outlet,\n} from \"react-router-dom\";\n\nimport Navbar from \"./components/Navbar\";\nimport Footer from \"./components/Footer\";\n\nfunction App() {\n  return (\n    <>\n      <Navbar />\n      <Outlet />\n      <Footer />\n    </>\n  );\n}\n\nexport default App;\n","/Users/sovin/personal_website/src/components/Footer.js",["89"],[],"import React, { useState } from \"react\";\nimport { Link } from \"react-router-dom\";\nimport {\n  BsFacebook,\n  BsTwitter,\n  BsGithub,\n  BsInstagram,\n  BsLinkedin,\n  BsSpotify,\n} from \"react-icons/bs\";\nimport \"./Footer.css\";\nimport { IconContext } from \"react-icons\";\n\nfunction Footer() {\n  return (\n    <div class=\"footer__container\">\n      <div class=\"social__media\">\n        <div class=\"social__media--wrap\">\n          <div class=\"footer__logo\">\n            <Link to=\"/\" id=\"footer__logo\">\n              Sovin Birla\n            </Link>\n          </div>\n          <div class=\"social__icons\">\n            <IconContext.Provider value={{ className: \"social__icon--link\" }}>\n              <Link to=\"https://www.facebook.com/profile.php?id=100008394522359\">\n                <BsFacebook />\n              </Link>\n              <Link to=\"https://github.com/sovinbirla\">\n                <BsGithub />\n              </Link>\n              <Link to=\"https://www.instagram.com/sovin_birla/\">\n                <BsInstagram />\n              </Link>\n              <Link to=\"https://www.linkedin.com/in/sovin-birla-421416148/\">\n                <BsLinkedin />\n              </Link>\n              <Link to=\"https://twitter.com/SovinBirla\">\n                <BsTwitter />\n              </Link>\n              <Link to=\"https://open.spotify.com/user/32tspal6zzctn2sl91ssm790t\">\n                <BsSpotify />\n              </Link>\n            </IconContext.Provider>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n\nexport default Footer;\n",{"ruleId":"90","severity":1,"message":"91","line":6,"column":3,"nodeType":"92","messageId":"93","endLine":6,"endColumn":8},{"ruleId":"90","severity":1,"message":"94","line":7,"column":3,"nodeType":"92","messageId":"93","endLine":7,"endColumn":7},{"ruleId":"90","severity":1,"message":"95","line":8,"column":3,"nodeType":"92","messageId":"93","endLine":8,"endColumn":9},{"ruleId":"90","severity":1,"message":"96","line":12,"column":8,"nodeType":"92","messageId":"93","endLine":12,"endColumn":14},{"ruleId":"90","severity":1,"message":"97","line":4,"column":20,"nodeType":"92","messageId":"93","endLine":4,"endColumn":26},{"ruleId":"90","severity":1,"message":"91","line":5,"column":3,"nodeType":"92","messageId":"93","endLine":5,"endColumn":8},{"ruleId":"90","severity":1,"message":"98","line":6,"column":3,"nodeType":"92","messageId":"93","endLine":6,"endColumn":9},{"ruleId":"90","severity":1,"message":"99","line":7,"column":3,"nodeType":"92","messageId":"93","endLine":7,"endColumn":9},{"ruleId":"90","severity":1,"message":"100","line":4,"column":8,"nodeType":"92","messageId":"93","endLine":4,"endColumn":12},{"ruleId":"90","severity":1,"message":"101","line":5,"column":8,"nodeType":"92","messageId":"93","endLine":5,"endColumn":13},{"ruleId":"90","severity":1,"message":"102","line":6,"column":8,"nodeType":"92","messageId":"93","endLine":6,"endColumn":16},{"ruleId":"90","severity":1,"message":"103","line":7,"column":8,"nodeType":"92","messageId":"93","endLine":7,"endColumn":15},{"ruleId":"90","severity":1,"message":"94","line":3,"column":10,"nodeType":"92","messageId":"93","endLine":3,"endColumn":14},{"ruleId":"90","severity":1,"message":"97","line":5,"column":20,"nodeType":"92","messageId":"93","endLine":5,"endColumn":26},{"ruleId":"90","severity":1,"message":"91","line":6,"column":3,"nodeType":"92","messageId":"93","endLine":6,"endColumn":8},{"ruleId":"90","severity":1,"message":"98","line":7,"column":3,"nodeType":"92","messageId":"93","endLine":7,"endColumn":9},{"ruleId":"90","severity":1,"message":"99","line":8,"column":3,"nodeType":"92","messageId":"93","endLine":8,"endColumn":9},{"ruleId":"90","severity":1,"message":"104","line":10,"column":10,"nodeType":"92","messageId":"93","endLine":10,"endColumn":16},{"ruleId":"90","severity":1,"message":"105","line":129,"column":10,"nodeType":"92","messageId":"93","endLine":129,"endColumn":17},{"ruleId":"90","severity":1,"message":"94","line":2,"column":10,"nodeType":"92","messageId":"93","endLine":2,"endColumn":14},{"ruleId":"90","severity":1,"message":"97","line":4,"column":20,"nodeType":"92","messageId":"93","endLine":4,"endColumn":26},{"ruleId":"90","severity":1,"message":"91","line":5,"column":3,"nodeType":"92","messageId":"93","endLine":5,"endColumn":8},{"ruleId":"90","severity":1,"message":"98","line":6,"column":3,"nodeType":"92","messageId":"93","endLine":6,"endColumn":9},{"ruleId":"90","severity":1,"message":"99","line":7,"column":3,"nodeType":"92","messageId":"93","endLine":7,"endColumn":9},{"ruleId":"90","severity":1,"message":"106","line":14,"column":9,"nodeType":"92","messageId":"93","endLine":14,"endColumn":19},{"ruleId":"90","severity":1,"message":"94","line":4,"column":10,"nodeType":"92","messageId":"93","endLine":4,"endColumn":14},{"ruleId":"107","severity":1,"message":"108","line":17,"column":11,"nodeType":"109","endLine":17,"endColumn":6576},{"ruleId":"90","severity":1,"message":"110","line":1,"column":8,"nodeType":"92","messageId":"93","endLine":1,"endColumn":12},{"ruleId":"90","severity":1,"message":"101","line":3,"column":8,"nodeType":"92","messageId":"93","endLine":3,"endColumn":13},{"ruleId":"90","severity":1,"message":"100","line":4,"column":8,"nodeType":"92","messageId":"93","endLine":4,"endColumn":12},{"ruleId":"90","severity":1,"message":"102","line":5,"column":8,"nodeType":"92","messageId":"93","endLine":5,"endColumn":16},{"ruleId":"90","severity":1,"message":"103","line":6,"column":8,"nodeType":"92","messageId":"93","endLine":6,"endColumn":15},{"ruleId":"90","severity":1,"message":"111","line":7,"column":17,"nodeType":"92","messageId":"93","endLine":7,"endColumn":25},{"ruleId":"90","severity":1,"message":"97","line":9,"column":20,"nodeType":"92","messageId":"93","endLine":9,"endColumn":26},{"ruleId":"90","severity":1,"message":"94","line":10,"column":3,"nodeType":"92","messageId":"93","endLine":10,"endColumn":7},{"ruleId":"90","severity":1,"message":"91","line":11,"column":3,"nodeType":"92","messageId":"93","endLine":11,"endColumn":8},{"ruleId":"90","severity":1,"message":"98","line":12,"column":3,"nodeType":"92","messageId":"93","endLine":12,"endColumn":9},{"ruleId":"90","severity":1,"message":"99","line":13,"column":3,"nodeType":"92","messageId":"93","endLine":13,"endColumn":9},{"ruleId":"90","severity":1,"message":"111","line":1,"column":17,"nodeType":"92","messageId":"93","endLine":1,"endColumn":25},"no-unused-vars","'Route' is defined but never used.","Identifier","unusedVar","'Link' is defined but never used.","'Outlet' is defined but never used.","'Navbar' is defined but never used.","'Router' is defined but never used.","'Routes' is defined but never used.","'Switch' is defined but never used.","'Home' is defined but never used.","'About' is defined but never used.","'Projects' is defined but never used.","'Contact' is defined but never used.","'render' is defined but never used.","'Project' is defined but never used.","'myFunction' is assigned a value but never used.","jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOpeningElement","'logo' is defined but never used.","'useState' is defined but never used."]